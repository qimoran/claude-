{
  "name": "claude-code-gui-server",
  "version": "1.0.0",
  "description": "后台管理 + API 中转服务",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
